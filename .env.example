# ============================================================
#  Dragon Crypto Oracle — Environment Variables Template
#
#  1. Copy this file:    cp .env.example .env
#  2. Fill in your keys below.
#  3. NEVER commit the actual .env file — it is in .gitignore!
# ============================================================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Binance API credentials (create at https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Google Gemini API key (FREE tier — create at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Admin Telegram user ID (your personal Telegram user ID, used for watcher alerts)
ADMIN_CHAT_ID=

# UI Language for the bot interface (e.g. uk, en, es, de, ru, fr, pl)
UI_LANGUAGE=uk

# Gemini model to use for AI analysis
GEMINI_MODEL=gemini-3-flash
